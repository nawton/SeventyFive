{
  "expo": {
    "name": "SeventyFive",
    "slug": "seventyfive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "seventyfive",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nawton.seventyfive",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Vi använder din plats för att spåra din löprutt."
      }
    },
    "android": {
      "package": "com.nawton.seventyfive",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Vi använder din plats för att spåra din löprutt."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
